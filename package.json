{
  "name": "service-ixcsoft",
  "description": "IXC Soft + Woovi PIX integration microservice",
  "version": "0.1.0",
  "author": "Woovi",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file .env --import tsx/esm src/index.ts",
    "build": "node esbuild.config.js",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "docker:build:local": "bash docker/build-local.sh",
    "docker:build:staging": "bash docker/build-docker-staging.sh",
    "docker:build:production": "bash docker/build-docker-production.sh",
    "docker:build:k8s": "bash docker/build-docker-k8s.sh",
    "docker:run": "bash docker/run.sh",
    "docker:update-locks": "bash docker/update-docker-locks.sh"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^14.0.0",
    "@sentry/node": "^10.5.0",
    "@woovi/apiwithlog": "^2.8.0",
    "@woovi/logger": "^1.0.1",
    "bullmq": "^5.57.0",
    "elastic-apm-node": "^4.13.0",
    "ioredis": "^5.7.0",
    "koa": "^3.0.1",
    "koa-bodyparser": "^4.4.1",
    "mongoose": "^9.5.0",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "undici": "^7.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "~5.0.2",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.9",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
